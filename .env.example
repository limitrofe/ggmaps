# Token do Mapbox (servido so a usuarios autenticados pela API, nunca no bundle)
MAPBOX_TOKEN=

# Banco
POSTGRES_PASSWORD=
DATABASE_URL=postgres://mapbox:senha@localhost:5432/mapbox

# Segredo para assinar a sessao (Fase 2). Gere com: openssl rand -hex 32
SESSION_SECRET=

# Porta do servidor
PORT=3000
