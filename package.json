{
  "name": "gerador-mapbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gerador de mapas Mapbox multiusuario (self-hosted)",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"node --watch server/index.js\"",
    "build": "vite build",
    "start": "node server/index.js",
    "migrate": "node server/migrate.js",
    "seed:admin": "node server/seed-admin.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "vite": "^6.0.0"
  }
}
